# =============================================================================
# PharmIQ Demo — Local Environment Variables
# Copy this to .env.local and fill in actual values
# =============================================================================

# ----- Database (Local Supabase Docker) -----
# These are PUBLIC, WELL-KNOWN demo JWTs that Supabase ships with self-hosted
# Docker installations. They are safe to commit because they only authenticate
# against your local Docker container on localhost. NEVER use these in production —
# Supabase Cloud generates unique per-project keys.
# Reference: https://github.com/supabase/supabase/blob/master/docker/.env.example
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<copy-from-supabase-docker-readme-or-leave-blank-for-direct-postgres>
SUPABASE_SERVICE_ROLE_KEY=<copy-from-supabase-docker-readme-or-leave-blank-for-direct-postgres>

# ----- LLM Provider Rotation Chain (free tiers) -----
# 1. Google AI Studio — Gemini 3 Flash Preview
GOOGLE_AI_API_KEY=

# 2. GitHub Models — Claude Sonnet 4.6 / GPT-5 mini / Cohere Embed v3
GITHUB_TOKEN=

# 3. Mistral La Plateforme — Mistral Large 3 (1B token/month free)
MISTRAL_API_KEY=

# 4. Groq — Llama 4 Scout (rate-limit emergency exit)
GROQ_API_KEY=

# ----- External Sources -----
# PubMed E-utilities — no key required for basic use, optional for higher limits
PUBMED_API_KEY=
PUBMED_EMAIL=

# ----- App Config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NODE_ENV=development
