# =============================================================================
# PharmIQ — local environment. Copy to .env.local and fill in the values.
#   cp apps/web/.env.example apps/web/.env.local
# =============================================================================

# --- Database: Postgres + pgvector (local Docker via `pnpm db:up`) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Embedding: local & free via Ollama (run `ollama pull bge-m3`) ---
# bge-m3 is 1024-dim and matches the DB schema. Set to `gemini` for a hosted option.
EMBEDDING_PROVIDER=ollama          # ollama | gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# --- Generation: automatic failover chain  Gemini -> Groq -> GitHub ---
# At least one key below is required.
GOOGLE_AI_API_KEY=                 # Google AI Studio (Gemini) — https://aistudio.google.com
GROQ_API_KEY=                      # Groq (free, fast Llama) — https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
# GITHUB_MODELS_TOKEN=             # optional: classic PAT to enable GitHub Models

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NODE_ENV=development
