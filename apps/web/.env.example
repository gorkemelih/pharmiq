
# --- Embedding sağlayıcı (Adım 1: kotayı kurtarmak için Ollama) ---
EMBEDDING_PROVIDER=ollama   # ollama (lokal/ücretsiz) | gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# --- Generation saglayici (Groq: ucretsiz/hizli, Llama). Gemini kotasini korur. ---
# Ucretsiz key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
